# ── Transport ──────────────────────────────────────────────────────────
# MCP_TRANSPORT_TYPE=stdio          # stdio | http (default: stdio)
# MCP_HTTP_PORT=3010                # HTTP port (default: 3010)
# MCP_HTTP_HOST=localhost           # HTTP host (default: localhost)
# MCP_HTTP_ENDPOINT_PATH=/mcp      # HTTP endpoint path (default: /mcp)
# MCP_PUBLIC_URL=                   # Public-facing origin override for TLS-terminating proxies (e.g., https://mcp.example.com)

# ── Auth ──────────────────────────────────────────────────────────────
# MCP_AUTH_MODE=none                # none | jwt | oauth (default: none)
# MCP_AUTH_SECRET_KEY=              # JWT secret (required for jwt mode)

# ── Storage ───────────────────────────────────────────────────────────
# STORAGE_PROVIDER_TYPE=in-memory   # in-memory | filesystem | supabase | cloudflare-r2 | cloudflare-kv | cloudflare-d1

# ── Session ──────────────────────────────────────────────────────────
# MCP_SESSION_MODE=stateful         # stateful | stateless (default: stateful)

# ── Request limits ────────────────────────────────────────────────────
# MCP_HTTP_MAX_BODY_BYTES=1048576   # Inbound request body cap in bytes (default: 1 MiB). Set 0 to disable.

# ── Logging ───────────────────────────────────────────────────────────
# MCP_LOG_LEVEL=info                # debug | info | notice | warning | error

# ── Telemetry ─────────────────────────────────────────────────────────
# OTEL_ENABLED=false                          # Enable OpenTelemetry (default: false)
# OTEL_EXPORTER_OTLP_ENDPOINT=               # OTLP endpoint URL (e.g., http://localhost:4318)

# ── SEC EDGAR ────────────────────────────────────────────────────────
EDGAR_USER_AGENT=                         # Required. Format: "AppName contact@email.com"
# EDGAR_RATE_LIMIT_RPS=10                 # Max requests/second to SEC APIs (max 10)
# EDGAR_TICKER_CACHE_TTL=3600             # Seconds to cache company_tickers.json

# ── SEC EDGAR local mirror (opt-in, Node/Bun only) ────────────────────
# Mirror company_tickers + XBRL company-facts into local SQLite to skip the
# live rate limit. After enabling, bootstrap once with `bun run mirror:init`.
# EDGAR_MIRROR_ENABLED=false              # Enable the local mirror (off by default)
# EDGAR_MIRROR_PATH=./data/edgar-mirror   # Directory for the mirror SQLite databases
# EDGAR_MIRROR_REFRESH_CRON=              # In-process nightly refresh (HTTP only); recommended "0 9 * * *". Omit to refresh via `bun run mirror:refresh`.
# EDGAR_MIRROR_FALLBACK_LIVE=true         # Fall back to the live API on a mirror miss (default true)

{
  "name": "@cyanheads/secedgar-mcp-server",
  "version": "0.11.0",
  "description": "Query SEC EDGAR filings, XBRL financials, and company data through MCP. STDIO & Streamable HTTP.",
  "mcpName": "io.github.cyanheads/secedgar-mcp-server",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "secedgar-mcp-server": "dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "Dockerfile",
    "server.json",
    "scripts/edgar-mirror-init.ts",
    "scripts/edgar-mirror-refresh.ts",
    "scripts/edgar-mirror-verify.ts",
    "scripts/_mirror-context.ts"
  ],
  "scripts": {
    "build": "bun scripts/build.ts",
    "rebuild": "bun scripts/clean.ts && bun scripts/build.ts",
    "clean": "bun scripts/clean.ts",
    "devcheck": "bun scripts/devcheck.ts",
    "tree": "bun scripts/tree.ts",
    "format": "biome check --write .",
    "format:unsafe": "biome check --write --unsafe .",
    "lint:mcp": "bun scripts/lint-mcp.ts",
    "changelog:build": "bun scripts/build-changelog.ts",
    "changelog:check": "bun scripts/build-changelog.ts --check",
    "list-skills": "bun scripts/list-skills.ts",
    "lint:packaging": "bun scripts/lint-packaging.ts",
    "bundle": "bun run build && bunx -y @anthropic-ai/mcpb pack . dist/secedgar-mcp-server.mcpb && bun run scripts/clean-mcpb.ts dist/secedgar-mcp-server.mcpb",
    "audit:refresh": "rm -f bun.lock && bun install && bun audit",
    "test": "vitest run",
    "mirror:init": "bun scripts/edgar-mirror-init.ts",
    "mirror:refresh": "bun scripts/edgar-mirror-refresh.ts",
    "mirror:verify": "bun scripts/edgar-mirror-verify.ts",
    "gen:former-names": "bun scripts/gen-former-names.ts",
    "release:github": "bun scripts/release-github.ts",
    "publish-mcp": "mcp-publisher login github -token \"$(security find-generic-password -a \"$USER\" -s mcp-publisher-github-pat -w)\" && mcp-publisher publish",
    "start": "node dist/index.js",
    "start:stdio": "MCP_TRANSPORT_TYPE=stdio node dist/index.js",
    "start:http": "MCP_TRANSPORT_TYPE=http node dist/index.js"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "sec",
    "edgar",
    "sec-edgar",
    "xbrl",
    "filings",
    "financial-data",
    "typescript",
    "bun",
    "stdio",
    "streamable-http"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyanheads/secedgar-mcp-server.git"
  },
  "homepage": "https://github.com/cyanheads/secedgar-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/cyanheads/secedgar-mcp-server/issues"
  },
  "author": "cyanheads <casey@caseyjhand.com> (https://github.com/cyanheads/secedgar-mcp-server#readme)",
  "license": "Apache-2.0",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/cyanheads"
    },
    {
      "type": "buy_me_a_coffee",
      "url": "https://www.buymeacoffee.com/cyanheads"
    }
  ],
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.11",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@cyanheads/mcp-ts-core": "^0.10.6",
    "@duckdb/node-api": "^1.5.3-r.3",
    "better-sqlite3": "^12.10.0",
    "domhandler": "^6.0.1",
    "domutils": "^4.0.2",
    "fflate": "^0.8.3",
    "html-to-text": "^10.0.0",
    "htmlparser2": "^12.0.0",
    "node-cron": "^4.2.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/html-to-text": "^9.0.4",
    "@types/node": "^25.9.3",
    "depcheck": "^1.4.7",
    "ignore": "^7.0.5",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
